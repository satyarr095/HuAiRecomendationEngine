{
  "family": "ai-recommendation-engine",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::890742594683:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::890742594683:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "ai-backend",
      "image": "890742594683.dkr.ecr.us-east-1.amazonaws.com/ai-backend:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-recommendation-engine",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      },
      "environment": [
        {
          "name": "PYTHONPATH",
          "value": "/app"
        },
        {
          "name": "PYTHONUNBUFFERED",
          "value": "1"
        }
      ]
    },
    {
      "name": "ai-frontend",
      "image": "890742594683.dkr.ecr.us-east-1.amazonaws.com/ai-frontend:latest",
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ai-recommendation-engine",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "frontend"
        }
      }
    }
  ]
} 